---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import HeroSection from "../components/HeroSection.astro";
import HistoriaSection from "../components/HistoriaSection.astro";
import WinesSection from "../components/WinesSection.astro";
import ReconocimientosSection from "../components/ReconocimientosSection.astro";
import TerrunoSection from "../components/TerrunoSection.astro";
import ContactoSection from "../components/ContactoSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout
    title="Cava Zaragoza | Vinos Artesanales del Valle de Guadalupe"
    description="Descubre vinos artesanales de calidad en Valle de Guadalupe. Cava boutique con Malbec, Cabernet Sauvignon, Syrah y más. Visítanos en Ensenada, Baja California."
    url="https://cavazaragoza.com.mx"
>
    <Navbar />
    <main id="main-content">
        <HeroSection />
        <HistoriaSection />
        <WinesSection />
        <ReconocimientosSection />
        <TerrunoSection />
        <ContactoSection />
    </main>
    <Footer />
</Layout>
