---
import { Image } from "astro:assets";
import cavaLogo from "../assets/cava-logo.png";
---

<footer class="bg-charcoal text-white pt-20 pb-10 border-t border-white/10">
    <div class="container mx-auto px-4">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16"
        >
            <!-- Brand -->
            <div class="col-span-1 lg:col-span-1">
                <div class="flex items-center gap-2 mb-4">
                    <span class="font-serif text-xl font-bold"
                        ><Image
                            src={cavaLogo}
                            alt="Cava Zaragoza Logo"
                            width={300}
                            height={300}
                            class="w-32 h-auto"
                        /></span
                    >
                </div>
                <p class="text-gray-400 text-sm leading-relaxed mb-6">
                    Pasión por la viticultura, respeto por la tierra y amor por
                    la tradición. El orgullo del Valle de Guadalupe en cada
                    botella.
                </p>
                <div class="flex gap-4">
                    <a
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary transition-colors"
                        href="#"
                    >
                        <span class="material-symbols-outlined text-sm"
                            >public</span
                        >
                        <!-- Social placeholder -->
                    </a>
                    <a
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary transition-colors"
                        href="#"
                    >
                        <span class="material-symbols-outlined text-sm"
                            >photo_camera</span
                        >
                        <!-- Social placeholder -->
                    </a>
                    <a
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary transition-colors"
                        href="#"
                    >
                        <span class="material-symbols-outlined text-sm"
                            >alternate_email</span
                        >
                        <!-- Social placeholder -->
                    </a>
                </div>
            </div>
            <!-- Links -->
            <div>
                <h4
                    class="font-bold uppercase tracking-widest text-sm mb-6 text-gold"
                >
                    Explorar
                </h4>
                <ul class="space-y-4 text-sm text-gray-400">
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Nuestra Historia</a
                        >
                    </li>
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Nuestros Vinos</a
                        >
                    </li>
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Club de Vinos</a
                        >
                    </li>
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Eventos</a
                        >
                    </li>
                </ul>
            </div>
            <!-- Legal -->
            <div>
                <h4
                    class="font-bold uppercase tracking-widest text-sm mb-6 text-gold"
                >
                    Legal
                </h4>
                <ul class="space-y-4 text-sm text-gray-400">
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Aviso de Privacidad</a
                        >
                    </li>
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Términos y Condiciones</a
                        >
                    </li>
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Envíos y Devoluciones</a
                        >
                    </li>
                    <li>
                        <a class="hover:text-white transition-colors" href="#"
                            >Política de Cookies</a
                        >
                    </li>
                </ul>
            </div>
            <!-- Newsletter -->
            <div>
                <h4
                    class="font-bold uppercase tracking-widest text-sm mb-6 text-gold"
                >
                    Newsletter
                </h4>
                <p class="text-gray-400 text-sm mb-4">
                    Suscríbete para recibir noticias exclusivas y ofertas
                    especiales.
                </p>
                <form class="flex flex-col gap-3">
                    <input
                        class="bg-white/5 border border-white/10 rounded px-4 py-2 text-sm text-white focus:border-primary outline-none"
                        placeholder="Tu correo electrónico"
                        type="email"
                    />
                    <button
                        class="bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded text-sm font-bold uppercase tracking-widest transition-colors"
                    >
                        Suscribirse
                    </button>
                </form>
            </div>
        </div>
        <div
            class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
        >
            <p class="text-gray-500 text-xs">
                © 2024 Cava Zaragoza. Todos los derechos reservados.
            </p>
            <div class="flex items-center gap-2 text-gray-500 text-xs">
                <span class="material-symbols-outlined text-base"
                    >local_bar</span
                >
                <span
                    >El abuso en el consumo de este producto es nocivo para la
                    salud.</span
                >
            </div>
        </div>
    </div>
</footer>
