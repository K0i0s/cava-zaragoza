---
import { Image } from "astro:assets";
import cavaLogo from "../assets/images/cava-logo.webp";
import heroDesktop from "../assets/images/hero_desktop.webp";
import heroDesktop2 from "../assets/images/hero_image_desktop_2.webp";
import heroMobile from "../assets/images/hero_mobile.webp";

const slides = [
    {
        desktop: heroDesktop,
        mobile: heroMobile,
        alt: "Viñedos del Valle de Guadalupe — Cava Zaragoza",
    },
    {
        desktop: heroDesktop2,
        mobile: heroDesktop2,
        alt: "Cava Zaragoza — Vinos Artesanales del Valle",
    },
];
---

<section
    id="inicio"
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
    <!-- Carousel Track -->
    <div id="hero-carousel" class="absolute inset-0 w-full h-full">
        {
            slides.map((slide, i) => (
                <div
                    class="hero-slide absolute inset-0 w-full h-full transition-opacity duration-1000"
                    data-index={i}
                    aria-hidden={i !== 0}
                    style={
                        i === 0
                            ? "opacity:1; z-index:1;"
                            : "opacity:0; z-index:0;"
                    }
                >
                    <!-- Mobile image -->
                    <Image
                        src={slide.mobile}
                        alt={slide.alt}
                        class="md:hidden absolute inset-0 w-full h-full object-cover object-center"
                        loading="eager"
                        fetchpriority={i === 0 ? "high" : "auto"}
                     />
                    <!-- Desktop image -->
                    <Image
                        src={slide.desktop}
                        alt={slide.alt}
                        class="hidden md:block absolute inset-0 w-full h-full object-cover object-center"
                        loading="eager"
                        fetchpriority={i === 0 ? "high" : "auto"}
                    />
                </div>
            ))
        }
    </div>

    <!-- Layered Overlays -->
    <div
        class="absolute inset-0 z-10"
        style="background: linear-gradient(to bottom, rgba(18,10,12,0.4) 0%, rgba(18,10,12,0.2) 40%, rgba(18,10,12,0.7) 80%, rgba(18,10,12,0.95) 100%);"
    >
    </div>
    <div
        class="absolute inset-0 z-10"
        style="background: radial-gradient(ellipse at center, transparent 40%, rgba(18,10,12,0.5) 100%);"
    >
    </div>

    <!-- Decorative gold line top -->
    <div
        class="absolute top-0 left-0 right-0 h-px z-20"
        style="background: linear-gradient(to right, transparent, rgba(212,175,55,0.4), transparent);"
    >
    </div>

    <!-- Hero Content -->
    <div
        class="relative z-20 text-center px-6 sm:px-8 max-w-4xl mx-auto pt-24 pb-20"
    >
        <!-- Label -->
        <p
            class="section-label mb-6 animate-fade-in"
            style="animation-delay: 0.2s;"
        >
            Valle de Guadalupe · Baja California
        </p>

        <!-- Decorative ornament -->
        <div
            class="flex items-center justify-center gap-4 mb-8 animate-fade-in"
            style="animation-delay: 0.4s;"
        >
            <div
                style="height: 1px; width: 3rem; background: linear-gradient(to right, transparent, var(--color-gold));"
            >
            </div>
            <svg
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
            >
                <path
                    d="M10 2L11.5 8.5L18 10L11.5 11.5L10 18L8.5 11.5L2 10L8.5 8.5L10 2Z"
                    fill="#D4AF37"
                    opacity="0.8"></path>
            </svg>
            <div
                style="height: 1px; width: 3rem; background: linear-gradient(to left, transparent, var(--color-gold));"
            >
            </div>
        </div>

        <!-- Main Headline -->
        <Image
            src={cavaLogo}
            alt="Cava Zaragoza"
            loading="eager"
            fetchpriority="high"
            width={1536}
            height={1024}
            layout="constrained"
        />
        <!-- Subheadline -->
        <p
            class="text-base sm:text-lg md:text-xl text-cream/80 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-up"
            style="font-family: var(--font-family-body); font-weight: 300; animation-delay: 0.5s;"
        >
            El sueño de Don Zaragoza, hecho vino. Desde el corazón del Valle
            hasta tu copa, con autenticidad artesanal y la pasión de quien ama
            la tierra.
        </p>

        <!-- CTA Buttons -->
        <div
            class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-up"
            style="animation-delay: 0.7s;"
        >
            <a href="/vinos" class="btn-outline min-w-[295px] sm:min-w-fit">
                Descubre Nuestros Vinos
            </a>
            <a
                href="/reservar"
                class="btn-primary min-w-[295px] sm:min-w-fit justify-center sm:justify-start text-center sm:text-left"
            >
                Reservar
            </a>
        </div>

        <!-- Scroll indicator -->
        <div
            class="absolute bottom-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-fade-in"
            style="animation-delay: 1.2s;"
        >
            <div class="w-px h-10 bg-gradient-to-b from-gold/60 to-transparent">
            </div>
        </div>
    </div>

    <!-- Carousel Dots -->
    <div
        id="hero-dots"
        class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex gap-3"
        aria-label="Carousel navigation"
    >
        {
            slides.map((_, i) => (
                <button
                    class="hero-dot w-3 h-3 rounded-full border border-gold/60 transition-all duration-500 cursor-pointer"
                    data-index={i}
                    aria-label={`Slide ${i + 1}`}
                    style={
                        i === 0
                            ? "background: var(--color-gold); transform: scale(1.3);"
                            : "background: transparent;"
                    }
                />
            ))
        }
    </div>
</section>

<script>
    const slides = document.querySelectorAll<HTMLElement>(".hero-slide");
    const dots = document.querySelectorAll<HTMLElement>(".hero-dot");
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
        // Hide current
        slides[current].style.opacity = "0";
        slides[current].style.zIndex = "0";
        slides[current].setAttribute("aria-hidden", "true");
        dots[current].style.background = "transparent";
        dots[current].style.transform = "scale(1)";

        // Show next
        current = index;
        slides[current].style.opacity = "1";
        slides[current].style.zIndex = "1";
        slides[current].setAttribute("aria-hidden", "false");
        dots[current].style.background = "var(--color-gold)";
        dots[current].style.transform = "scale(1.3)";
    }

    function next() {
        goTo((current + 1) % slides.length);
    }

    function startTimer() {
        timer = setInterval(next, 8000);
    }

    function resetTimer() {
        clearInterval(timer);
        startTimer();
    }

    // Dot click navigation
    dots.forEach((dot) => {
        dot.addEventListener("click", () => {
            const idx = Number(dot.dataset.index);
            if (idx !== current) {
                goTo(idx);
                resetTimer();
            }
        });
    });

    // Start autoplay
    startTimer();

    // Pause on hover / touch
    const section = document.getElementById("inicio")!;
    section.addEventListener("mouseenter", () => clearInterval(timer));
    section.addEventListener("mouseleave", startTimer);
</script>
