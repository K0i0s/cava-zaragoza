---
const hours = [
    { day: "Lunes – Jueves", hours: "Cerrado", open: false },
    { day: "Viernes", hours: "4:00 PM – 8:00 PM", open: true },
    { day: "Sábado", hours: "12:00 PM – 8:00 PM", open: true },
    { day: "Domingo", hours: "12:00 PM – 4:00 PM", open: true },
];
---

<section
    id="contacto"
    class="py-24 lg:py-36 relative overflow-hidden"
    style="background: var(--color-dark-card);"
>
    <!-- Background accent -->
    <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 80% 50%, rgba(139,21,56,0.1), transparent);"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-20 reveal">
            <p class="section-label mb-4">Visítanos</p>
            <span class="gold-divider"></span>
            <h2
                class="text-3xl sm:text-4xl md:text-5xl font-bold text-cream mt-4"
                style="font-family: var(--font-family-display);"
            >
                Contáctanos
            </h2>
            <p
                class="mt-4 text-cream/60 max-w-xl mx-auto text-base"
                style="font-family: var(--font-family-body); font-weight: 300;"
            >
                ¿Tienes preguntas sobre nuestros vinos o quieres agendar una
                visita? Escríbenos.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
            <!-- Contact Form -->
            <div class="reveal reveal-delay-1">
                <h3
                    class="text-xl font-bold text-cream mb-8"
                    style="font-family: var(--font-family-display);"
                >
                    Envíanos un Mensaje
                </h3>
                <form
                    action="mailto:vinos@cavazaragoza.com.mx"
                    method="post"
                    enctype="text/plain"
                    class="space-y-5"
                    aria-label="Formulario de contacto"
                >
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <!-- Nombre -->
                        <div>
                            <label
                                for="nombre"
                                class="block text-xs font-medium text-cream/70 mb-2 uppercase tracking-wider"
                                style="font-family: var(--font-family-body); letter-spacing: 0.1em; font-size: 0.65rem;"
                            >
                                Nombre *
                            </label>
                            <input
                                type="text"
                                id="nombre"
                                name="nombre"
                                required
                                placeholder="Tu nombre completo"
                                class="w-full px-4 py-3 text-sm text-cream placeholder-cream/30 bg-transparent rounded-sm outline-none transition-all duration-300 focus:border-gold/60"
                                style="background: rgba(245,245,220,0.04); border: 1px solid rgba(245,245,220,0.15); font-family: var(--font-family-body);"
                            />
                        </div>

                        <!-- Email -->
                        <div>
                            <label
                                for="email"
                                class="block text-xs font-medium text-cream/70 mb-2 uppercase tracking-wider"
                                style="font-family: var(--font-family-body); letter-spacing: 0.1em; font-size: 0.65rem;"
                            >
                                Email *
                            </label>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                placeholder="tu@email.com"
                                class="w-full px-4 py-3 text-sm text-cream placeholder-cream/30 bg-transparent rounded-sm outline-none transition-all duration-300 focus:border-gold/60"
                                style="background: rgba(245,245,220,0.04); border: 1px solid rgba(245,245,220,0.15); font-family: var(--font-family-body);"
                            />
                        </div>
                    </div>

                    <!-- Teléfono -->
                    <div>
                        <label
                            for="telefono"
                            class="block text-xs font-medium text-cream/70 mb-2 uppercase tracking-wider"
                            style="font-family: var(--font-family-body); letter-spacing: 0.1em; font-size: 0.65rem;"
                        >
                            Teléfono
                        </label>
                        <input
                            type="tel"
                            id="telefono"
                            name="telefono"
                            placeholder="+52 664 XXX XXXX"
                            class="w-full px-4 py-3 text-sm text-cream placeholder-cream/30 bg-transparent rounded-sm outline-none transition-all duration-300 focus:border-gold/60"
                            style="background: rgba(245,245,220,0.04); border: 1px solid rgba(245,245,220,0.15); font-family: var(--font-family-body);"
                        />
                    </div>

                    <!-- Mensaje -->
                    <div>
                        <label
                            for="mensaje"
                            class="block text-xs font-medium text-cream/70 mb-2 uppercase tracking-wider"
                            style="font-family: var(--font-family-body); letter-spacing: 0.1em; font-size: 0.65rem;"
                        >
                            Mensaje *
                        </label>
                        <textarea
                            id="mensaje"
                            name="mensaje"
                            required
                            rows={5}
                            placeholder="¿En qué podemos ayudarte? ¿Quieres agendar una visita o consultar disponibilidad de vinos?"
                            class="w-full px-4 py-3 text-sm text-cream placeholder-cream/30 bg-transparent rounded-sm outline-none transition-all duration-300 focus:border-gold/60 resize-none"
                            style="background: rgba(245,245,220,0.04); border: 1px solid rgba(245,245,220,0.15); font-family: var(--font-family-body);"
                        ></textarea>
                    </div>

                    <!-- Submit -->
                    <button
                        type="submit"
                        class="btn-primary w-full justify-center"
                        aria-label="Enviar mensaje a Cava Zaragoza"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            aria-hidden="true"
                        >
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"
                            ></path>
                        </svg>
                        Enviar Mensaje
                    </button>

                    <!-- WhatsApp alternate -->
                    <a
                        href="https://wa.me/526642178375?text=Hola,%20me%20interesa%20conocer%20más%20sobre%20Cava%20Zaragoza"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-outline w-full justify-center mt-3"
                        aria-label="Contactar por WhatsApp"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                            ></path>
                        </svg>
                        Escríbenos por WhatsApp
                    </a>
                </form>
            </div>

            <!-- Info Column -->
            <div class="reveal reveal-delay-2 space-y-8">
                <h3
                    class="text-xl font-bold text-cream"
                    style="font-family: var(--font-family-display);"
                >
                    Información de Contacto
                </h3>

                <!-- Address -->
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
                        style="background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.2);"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--color-gold)"
                            stroke-width="1.5"
                            aria-hidden="true"
                        >
                            <path
                                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
                            ></path>
                            <circle cx="12" cy="9" r="2.5"></circle>
                        </svg>
                    </div>
                    <div>
                        <p
                            class="text-xs text-gold/70 uppercase tracking-wider mb-1"
                            style="font-family: var(--font-family-body); font-size: 0.65rem; letter-spacing: 0.1em;"
                        >
                            Dirección
                        </p>
                        <address
                            class="not-italic text-sm text-cream/80 leading-relaxed"
                            style="font-family: var(--font-family-body);"
                        >
                            Calle Ágata, Col. 14 de Febrero<br />
                            Valle de Guadalupe 22756<br />
                            Ensenada, Baja California, México
                        </address>
                    </div>
                </div>

                <!-- Phone -->
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
                        style="background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.2);"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--color-gold)"
                            stroke-width="1.5"
                            aria-hidden="true"
                        >
                            <path
                                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p
                            class="text-xs text-gold/70 uppercase tracking-wider mb-1"
                            style="font-family: var(--font-family-body); font-size: 0.65rem; letter-spacing: 0.1em;"
                        >
                            Teléfono
                        </p>
                        <a
                            href="tel:+526642178375"
                            class="text-sm text-cream/80 hover:text-gold-light transition-colors duration-200"
                            style="font-family: var(--font-family-body);"
                        >
                            664 217 8375
                        </a>
                    </div>
                </div>

                <!-- Email -->
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center"
                        style="background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.2);"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--color-gold)"
                            stroke-width="1.5"
                            aria-hidden="true"
                        >
                            <path
                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                            ></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </div>
                    <div>
                        <p
                            class="text-xs text-gold/70 uppercase tracking-wider mb-1"
                            style="font-family: var(--font-family-body); font-size: 0.65rem; letter-spacing: 0.1em;"
                        >
                            Email
                        </p>
                        <a
                            href="mailto:vinos@cavazaragoza.com.mx"
                            class="text-sm text-cream/80 hover:text-gold-light transition-colors duration-200"
                            style="font-family: var(--font-family-body);"
                        >
                            vinos@cavazaragoza.com.mx
                        </a>
                    </div>
                </div>

                <!-- Hours -->
                <div>
                    <p
                        class="text-xs text-gold/70 uppercase tracking-wider mb-4"
                        style="font-family: var(--font-family-body); font-size: 0.65rem; letter-spacing: 0.1em;"
                    >
                        Horarios de Atención
                    </p>
                    <div class="space-y-2">
                        {
                            hours.map((h) => (
                                <div
                                    class="flex justify-between items-center py-2"
                                    style="border-bottom: 1px solid rgba(245,245,220,0.08);"
                                >
                                    <span
                                        class="text-sm text-cream/70"
                                        style="font-family: var(--font-family-body);"
                                    >
                                        {h.day}
                                    </span>
                                    <span
                                        class="text-sm font-medium"
                                        style={`font-family: var(--font-family-body); color: ${h.open ? "var(--color-gold)" : "rgba(245,245,220,0.35)"};`}
                                    >
                                        {h.hours}
                                    </span>
                                </div>
                            ))
                        }
                        <p
                            class="text-xs text-cream/40 mt-2 italic"
                            style="font-family: var(--font-family-body);"
                        >
                            *El horario podría cambiar sin previo aviso
                        </p>
                    </div>
                </div>

                <!-- Map Embed -->
                <div
                    class="rounded-sm overflow-hidden"
                    style="border: 1px solid rgba(212,175,55,0.2); height: 220px;"
                >
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1690.2565031418123!2d-116.5745365!3d32.0824181!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80d8f1d38660b6e5%3A0xe5bb1600b65cec29!2sCava%20ZARAGOZA!5e0!3m2!1ses!2smx!4v1771909443781!5m2!1ses!2smx"
                        width="100%"
                        height="100%"
                        style="border: 0; filter: grayscale(80%) invert(90%) sepia(20%);"
                        allowfullscreen
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Ubicación de Cava Zaragoza en Valle de Guadalupe"
                    ></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
