---
import { Image } from "astro:assets";
import visitasImg from "../assets/images/visita-cavazaragoza.webp";
import eventosImg from "../assets/images/eventos-cavazaragoza.webp";
import cabaniasImg from "../assets/images/cabanias-cavazaragoza.webp";

const experiences = [
    {
        tagline: "Visita y Degustación.",
        title: "Recorridos y Catas",
        description: "Exploración guiada por las instalaciones del viñedo y procesos de producción, concluyendo con una degustación estructurada de nuestras etiquetas.",
        cta: "Reservar recorrido",
        image: visitasImg,
        href: "/reservar?service=recorrido"
    },
    {
        tagline: "Estancia Prolongada",
        title: "Cabañas entre Vides",
        description: "Alojamiento de fin de semana en cabañas privadas. Un espacio diseñado para el descanso, ubicado directamente en el entorno natural del viñedo.",
        cta: "Reservar cabaña",
        badge: "Nueva apertura",
        image: cabaniasImg,
        href: "/reservar?service=cabanias"
    },
    {
        tagline: "Grupos y Celebraciones",
        title: "Eventos Privados",
        description: "Renta de espacios al aire libre rodeados de naturaleza y viñedos. Instalaciones acondicionadas para llevar a cabo reuniones y eventos exclusivos.",
        cta: "Agendar evento",
        image: eventosImg,
        href: "/reservar?service=eventos"
    }
];
---

<section
    id="experiencias"
    aria-label="Experiencias"
    class="experiences-section"
>
    <!-- Subtle grain overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <div class="experiences-container">
        <!-- Header -->
        <div class="experiences-header reveal">
            <p class="section-label">Experiencias</p>
            <div class="gold-divider"></div>
            <h2 class="experiences-title">
                Momentos <em class="experiences-title-accent">Inolvidables</em>
            </h2>
        </div>

        <!-- Grid Experiences -->
        <div class="experiences-grid">
            {experiences.map((exp, i) => (
                <div class={`experience-card reveal reveal-delay-${i + 1}`}>
                    <div class="experience-image-wrap">
                        <Image 
                            src={exp.image} 
                            alt={exp.title} 
                            class="experience-img" 
                            loading="lazy" 
                        />
                        <div class="experience-overlay"></div>
                    </div>
                    
                    {exp.badge && (
                        <div class="experience-badge">{exp.badge}</div>
                    )}

                    <div class="experience-content">
                        <p class="experience-tagline">{exp.tagline}</p>
                        <h3 class="experience-name">{exp.title}</h3>
                        
                        <div class="experience-details">
                            <p class="experience-description">{exp.description}</p>
                            <a href={exp.href} class="btn-primary">
                                {exp.cta}
                            </a>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .experiences-section {
        background: var(--color-dark-bg);
        position: relative;
        overflow: hidden;
    }

    /* Grain texture overlay */
    .grain-overlay {
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        background-size: 200px;
        pointer-events: none;
        opacity: 0.4;
        z-index: 1;
    }

    .experiences-container {
        max-width: 70rem;
        margin: 0 auto;
        padding: 6rem 1.5rem 5rem;
        position: relative;
        z-index: 2;
    }

    /* Header */
    .experiences-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .experiences-title {
        font-family: var(--font-family-display);
        font-size: clamp(2rem, 4.5vw, 3.2rem);
        font-weight: 700;
        color: var(--color-cream);
        line-height: 1.15;
        margin: 0;
    }

    .experiences-title-accent {
        font-style: italic;
        color: var(--color-gold);
    }

    /* Grid */
    .experiences-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        min-height: 60vh;
    }

    .experience-card {
        position: relative;
        overflow: hidden;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        border: 1px solid rgba(212, 175, 55, 0.1);
    }

    .experience-card:hover {
        transform: scale(1.02);
        border-color: rgba(212, 175, 55, 0.3);
    }

    .experience-image-wrap {
        position: absolute;
        inset: 0;
        z-index: 1;
    }

    .experience-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s ease;
        filter: brightness(0.7) contrast(1.1);
    }

    .experience-card:hover .experience-img {
        transform: scale(1.1);
        filter: brightness(0.5) contrast(1.2);
    }

    .experience-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            transparent 0%,
            transparent 40%,
            rgba(0, 0, 0, 0.4) 60%,
            rgba(10, 10, 10, 0.9) 100%
        );
        z-index: 2;
    }

    /* Badge */
    .experience-badge {
        font-family: var(--font-family-display);
        font-style: italic;
        font-size: 0.65rem;
        position: absolute;
        top: 2rem;
        right: 0;
        background: var(--color-gold);
        color: #000;
        font-weight: 800;
        letter-spacing: 0.15em;
        padding: 0.5rem 1rem;
        z-index: 5;
        text-transform: capitalize;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    }

    /* Content */
    .experience-content {
        position: relative;
        z-index: 3;
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .experience-tagline {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        color: var(--color-gold);
        text-transform: uppercase;
        margin: 0;
        transform: translateY(0);
        transition: transform 0.5s ease;
    }

    .experience-name {
        font-family: var(--font-family-display);
        font-size: 2.2rem;
        font-weight: 400;
        color: var(--color-cream);
        margin: 0;
        font-style: italic;
        line-height: 1.2;
    }

    .experience-details {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition: max-height 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .experience-card:hover .experience-details {
        max-height: 300px;
        opacity: 1;
        margin-top: 1rem;
    }

    .experience-description {
        font-family: var(--font-family-body);
        font-size: 0.95rem;
        line-height: 1.6;
        color: rgba(245, 245, 220, 0.85);
        margin: 0;
    }

    @media (max-width: 1024px) {
        .experiences-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .experience-card {
            height: 550px;
        }

        /* Show details by default on mobile as per requirement */
        .experience-details {
            max-height: none;
            opacity: 1;
            margin-top: 1rem;
        }

        .experience-content {
            padding: 2rem 1.5rem;
        }

        .experience-name {
            font-size: 1.8rem;
        }
    }

    @media (max-width: 768px) {
        .experience-card{
            height: 65vh;
        }

    }
</style>
