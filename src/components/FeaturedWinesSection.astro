---
/**
 * FeaturedWinesSection — Vitrina minimalista de los 3 vinos reconocidos por revista.
 * Diseño: botellas a pantalla completa con fondo transparente, solo nombre & añada abajo.
 * Las otras 2 imágenes se agregarán cuando el cliente las proporcione.
 */
import { Image } from "astro:assets";
import cabernetImg from "../assets/images/cabernet-sauvignon.webp";
import malbecImg from "../assets/images/malbec-2023.webp";
import cagreteImg from "../assets/images/Cagrete-blend-2023.png";

const featuredWines = [
    {
        id: 'malbec',
        name: 'Malbec',
        grapes: 'Malbec 100%',
        vintage: '2023',
        image: malbecImg,
        imageAlt: 'Botella Malbec — Cava Zaragoza medalla Oro Concurso Top 99',
    },
    {
        id: 'cabernet-sauvignon',
        name: 'Cabernet Sauvignon / Grenache',
        grapes: 'Cabernet Sauvignon · Grenache',
        vintage: '2022',
        image: cabernetImg,
        imageAlt: 'Botella Cabernet Sauvignon Grenache 2022 — Cava Zaragoza, medalla bronce Concurso Top 99',
    },
    {
        id: 'cagrete-blend-2023',
        name: 'Cagrete Blend',
        grapes: 'Mezcla de tintos',
        vintage: '2023',
        image: cagreteImg,
        imageAlt: 'Botella Cagrete Blend 2023 — Cava Zaragoza medalla de bronce',
    },
];
---

<section
    id="vinos-destacados"
    aria-label="Vinos Destacados"
    class="wines-featured-section"
>
    <!-- Subtle grain overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <div class="wines-container">
        <!-- Header -->
        <div class="wines-header reveal">
            <p class="section-label">Concurso Top 99 · Revista Cava 2025</p>
            <div class="gold-divider"></div>
            <h2 class="wines-title">
                Vinos <em class="wines-title-accent">Reconocidos</em>
            </h2>
        </div>

        <!-- Bottle Grid (podio: 1ro centro, 2do izq, 3ro der) -->
        <div class="bottles-grid">
            {featuredWines.map((wine, i) => {
                // rank: 0=1er, 1=2do, 2=3er
                // visual order: 2do→col1, 1ro→col2, 3ro→col3
                const rankClass = i === 0 ? 'rank-first' : i === 1 ? 'rank-second' : 'rank-third';
                const rankLabel = i === 0 ? '1°' : i === 1 ? '2°' : '3°';
                return (
                <a
                    href="/vinos"
                    class={`bottle-item reveal reveal-delay-${i + 1} ${rankClass}`}
                    aria-label={`Ver ${wine.name} en nuestra colección`}
                >
                    <!-- Rank badge -->
                    <div class="rank-badge" aria-hidden="true">{rankLabel}</div>

                    <!-- Bottle image -->
                    <div class="bottle-img-wrap">
                        <Image
                            src={wine.image}
                            alt={wine.imageAlt}
                            class="bottle-img"
                            loading={i === 0 ? "eager" : "lazy"}
                        />

                        <!-- Hover shimmer sweep -->
                        <div class="bottle-shine" aria-hidden="true"></div>
                        <!-- Glow ring -->
                        <div class="bottle-glow" aria-hidden="true"></div>
                    </div>

                    <!-- Caption -->
                    <div class="bottle-caption">
                        <h3 class="bottle-name">{wine.name}</h3>
                        <p class="bottle-grapes">{wine.grapes}</p>
                        {wine.vintage && (
                            <span class="bottle-vintage">{wine.vintage}</span>
                        )}
                    </div>
                </a>
                );
            })}
        </div>

        <!-- CTA -->
        <div class="wines-cta reveal">
            <a href="/vinos" class="btn-outline cta-btn" aria-label="Ver colección completa de vinos">
                Ver Colección Completa
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                    <path d="M2.5 7.5h10M9 3.5l4 4-4 4" stroke="currentColor" stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
    /* ── Section ── */
    .wines-featured-section {
        background: var(--color-dark-bg);
        position: relative;
        overflow: hidden;
    }

    /* Grain texture overlay */
    .grain-overlay {
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        background-size: 200px;
        pointer-events: none;
        opacity: 0.4;
    }

    /* ── Container ── */
    .wines-container {
        max-width: 70rem;
        margin: 0 auto;
        padding: 6rem 1.5rem 5rem;
        position: relative;
        z-index: 1;
    }

    @media (min-width: 1024px) {
        .wines-container {
            padding: 7rem 2rem 6rem;
        }
    }

    /* ── Header ── */
    .wines-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .wines-title {
        font-family: var(--font-family-display);
        font-size: clamp(2rem, 4.5vw, 3.2rem);
        font-weight: 700;
        color: var(--color-cream);
        line-height: 1.15;
        margin: 0;
    }

    .wines-title-accent {
        font-style: italic;
        color: var(--color-gold);
    }

    /* ── Bottles Grid — podio layout ── */
    .bottles-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 4rem;
        align-items: end;   /* alinear bases al bottom */
    }

    @media (max-width: 640px) {
        .bottles-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        /* en móvil restaurar orden natural */
        .rank-first  { order: 1; }
        .rank-second { order: 2; }
        .rank-third  { order: 3; }
    }

    /* ── Orden visual: 2do izq · 1ro centro · 3ro der ── */
    .rank-first  { order: 2; }   /* centro */
    .rank-second { order: 1; }   /* izquierda */
    .rank-third  { order: 3; }   /* derecha */

    /* ── Rank badge ── */
    .rank-badge {
        font-family: var(--font-family-display);
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        color: rgba(212, 175, 55, 0.5);
        text-transform: uppercase;
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 0.35s ease, transform 0.35s ease, color 0.35s ease;
    }
    .bottle-item:hover .rank-badge {
        opacity: 1;
        transform: translateY(0);
    }
    .rank-first .rank-badge  { color: rgba(212, 175, 55, 0.9); }
    .rank-second .rank-badge { color: rgba(212, 175, 55, 0.6); }
    .rank-third .rank-badge  { color: rgba(212, 175, 55, 0.45); }

    /* ── Bottle item (link) ── */
    .bottle-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
        outline: none;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    /* ── Bottle image wrapper — alturas de podio ── */
    .bottle-img-wrap {
        position: relative;
        width: 100%;
        max-width: 200px;
        margin: 0 auto;
        filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.5));
        transition: filter 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    /* Alturas escalonadas: 1ro más alto, 2do mediano, 3ro más bajo */
    .rank-first  .bottle-img-wrap { min-height: 360px; }
    .rank-second .bottle-img-wrap { min-height: 320px; }
    .rank-third  .bottle-img-wrap { min-height: 280px; }

    /* Contenido de la imagen alineado al bottom para que las bases coincidan */
    .bottle-img-wrap {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .bottle-item:hover .bottle-img-wrap {
        filter: drop-shadow(0 48px 90px rgba(139, 21, 56, 0.3))
                drop-shadow(0 0 50px rgba(212, 175, 55, 0.12));
        transform: translateY(-12px) scale(1.03);
    }

    /* Ampliar el lift para el 1ro */
    .rank-first:hover .bottle-img-wrap {
        transform: translateY(-16px) scale(1.04);
    }

    /* The actual bottle image — mismo tamaño en todos, solo el wrapper cambia de alto */
    .bottle-img {
        width: 100%;
        height: 360px;
        object-fit: contain;
        object-position: bottom;
        mix-blend-mode: normal;
        display: block;
        transition: filter 0.4s ease;
    }
    .bottle-item:hover .bottle-img {
        filter: brightness(1.06) contrast(1.04);
    }

    /* ── Pending bottle placeholder ── */
    .bottle-pending {
        width: 100%;
        aspect-ratio: 1 / 2.5;
        max-height: 340px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed rgba(212, 175, 55, 0.15);
        background: rgba(212, 175, 55, 0.01);
    }

    /* ── Shimmer sweep on hover ── */
    .bottle-shine {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            120deg,
            transparent 0%,
            transparent 30%,
            rgba(212, 175, 55, 0.10) 50%,
            transparent 70%,
            transparent 100%
        );
        background-size: 200% 100%;
        background-position: -100% 0;
        opacity: 0;
        transition: opacity 0.25s ease;
        pointer-events: none;
    }
    .bottle-item:hover .bottle-shine {
        opacity: 1;
        animation: shimmer-sweep 0.7s ease forwards;
    }
    @keyframes shimmer-sweep {
        from { background-position: -100% 0; }
        to   { background-position: 200% 0; }
    }

    /* ── Glow ring behind bottle ── */
    .bottle-glow {
        position: absolute;
        bottom: 0;
        left: 50%;
        translate: -50% 30%;
        width: 70%;
        height: 40%;
        border-radius: 50%;
        background: radial-gradient(ellipse, rgba(212, 175, 55, 0.18) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
        filter: blur(12px);
    }
    .bottle-item:hover .bottle-glow {
        opacity: 1;
    }
    .rank-first:hover .bottle-glow {
        background: radial-gradient(ellipse, rgba(212, 175, 55, 0.28) 0%, transparent 70%);
    }

    /* ── Caption ── */
    .bottle-caption {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        padding-top: 0.5rem;
        border-top: 1px solid rgba(212, 175, 55, 0.1);
        min-height: 120px;
        width: 100%;
        max-width: 220px;
        transition: border-color 0.3s ease;
    }

    .bottle-item:hover .bottle-caption {
        border-color: rgba(212, 175, 55, 0.35);
    }

    .bottle-name {
        font-family: var(--font-family-display);
        font-size: clamp(0.95rem, 1.8vw, 1.15rem);
        font-weight: 700;
        color: var(--color-cream);
        line-height: 1.25;
        margin: 0;
        transition: color 0.3s ease;
    }

    .bottle-item:hover .bottle-name {
        color: var(--color-gold-light);
    }

    .bottle-grapes {
        font-family: var(--font-family-body);
        font-size: 0.65rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(212, 175, 55, 0.5);
        margin: 0;
    }

    .bottle-vintage {
        font-family: var(--font-family-body);
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        color: rgba(245, 245, 220, 0.3);
    }

    /* ── CTA ── */
    .wines-cta {
        display: flex;
        justify-content: center;
    }

    .cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
    }
</style>
