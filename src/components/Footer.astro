---
import { navLinks } from "../lib/navigation";
import { Image } from "astro:assets";
import logo from "../assets/images/cava-logo.webp";
---

<footer
    style="background: var(--color-charcoal); border-top: 1px solid rgba(212,175,55,0.15);"
    role="contentinfo"
>
    <!-- Top footer -->
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <!-- Brand Column -->
            <div class="md:col-span-1">
                <a
                    href="/"
                    class="inline-flex items-center gap-3 mb-4 group"
                    aria-label="Cava Zaragoza - Inicio"
                >
                    <Image
                        src={logo}
                        alt="Cava Zaragoza"
                        width={1536}
                        height={1024}
                        layout="constrained"
                        class="h-13 w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity duration-300"
                        loading="lazy"
                    />
                </a>
                <p
                    class="text-sm text-cream/60 leading-relaxed max-w-xs mt-4"
                    style="font-family: var(--font-family-body); font-weight: 300;"
                >
                    Vinos artesanales del Valle de Guadalupe, Baja California.
                    Pasión, terroir y autenticidad en cada botella.
                </p>
                <!-- Social placeholder -->
                <div class="flex gap-3 mt-6">
                    <a
                        href="https://wa.me/526642178375"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:border-gold"
                        style="background: rgba(245,245,220,0.05); border: 1px solid rgba(245,245,220,0.15);"
                        aria-label="WhatsApp de Cava Zaragoza"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="var(--color-cream)"
                            opacity="0.7"
                            aria-hidden="true"
                        >
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="mailto:vinos@cavazaragoza.com.mx"
                        class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-300 hover:border-gold"
                        style="background: rgba(245,245,220,0.05); border: 1px solid rgba(245,245,220,0.15);"
                        aria-label="Email de Cava Zaragoza"
                    >
                        <svg
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="rgba(245,245,220,0.7)"
                            stroke-width="1.5"
                            aria-hidden="true"
                        >
                            <path
                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                            ></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Quick Links Column -->
            <div>
                <h3
                    class="text-xs text-gold/70 uppercase tracking-wider mb-6"
                    style="font-family: var(--font-family-body); letter-spacing: 0.15em; font-size: 0.65rem;"
                >
                    Navegación
                </h3>
                <ul class="space-y-3 list-none m-0 p-0">
                    {
                        navLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-sm text-cream/60 hover:text-gold-light transition-colors duration-200"
                                    style="font-family: var(--font-family-body);"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Contact Info Column -->
            <div>
                <h3
                    class="text-xs text-gold/70 uppercase tracking-wider mb-6"
                    style="font-family: var(--font-family-body); letter-spacing: 0.15em; font-size: 0.65rem;"
                >
                    Contacto
                </h3>
                <address class="not-italic space-y-3">
                    <p
                        class="text-sm text-cream/60 leading-relaxed"
                        style="font-family: var(--font-family-body);"
                    >
                        Calle Ágata, Artículo Ciento Quince<br />
                        Valle de Guadalupe 22756<br />
                        Ensenada, B.C., México
                    </p>
                    <a
                        href="tel:+526642178375"
                        class="block text-sm text-cream/60 hover:text-gold-light transition-colors duration-200"
                        style="font-family: var(--font-family-body);"
                    >
                        664 217 8375
                    </a>
                    <a
                        href="mailto:vinos@cavazaragoza.com.mx"
                        class="block text-sm text-cream/60 hover:text-gold-light transition-colors duration-200"
                        style="font-family: var(--font-family-body);"
                    >
                        vinos@cavazaragoza.com.mx
                    </a>
                </address>
            </div>
        </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid rgba(245,245,220,0.06);">
        <div
            class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3"
        >
            <p
                class="text-xs text-cream/50"
                style="font-family: var(--font-family-body);"
            >
                &copy; {new Date().getFullYear()} Cava Zaragoza. Todos los derechos
                reservados.
            </p>
            <p
                class="text-xs text-cream/50"
                style="font-family: var(--font-family-body);"
            >
                Valle de Guadalupe · Ensenada · Baja California · México
            </p>
        </div>
    </div>
</footer>
