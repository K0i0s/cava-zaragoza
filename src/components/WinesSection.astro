---
import { Image } from 'astro:assets';
import { wines } from '../lib/wines';
import malbecImg from '../assets/images/malbec.webp';
import cabernetImg from '../assets/images/cavernet_sauvignon_grenache.webp';
import sauvignonImg from '../assets/images/sauvignon-blanc-chardonnay.webp';
import tempranilloImg from '../assets/images/tempranillo.webp';
import rosadoImg from '../assets/images/yocelin_rose.webp';

const imageMap: Record<string, ImageMetadata> = {
  '/images/malbec.webp': malbecImg,
  '/images/cavernet_sauvignon_grenache.webp': cabernetImg,
  '/images/sauvignon-blanc-chardonnay.webp': sauvignonImg,
  '/images/tempranillo.webp': tempranilloImg,
  '/images/yocelin_rose.webp': rosadoImg,
};

const badgeStyles: Record<string, string> = {
  gold: 'color: var(--color-charcoal); background-color: var(--color-gold);',
  burgundy: 'color: var(--color-gold-pale); background-color: var(--color-burgundy);',
  olive: 'color: var(--color-cream); background-color: var(--color-olive);',
};
---

<section id="vinos" class="py-24 lg:py-36 relative" style="background: linear-gradient(to bottom, var(--color-dark-bg), var(--color-dark-card) 40%, var(--color-dark-bg) 100%);">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(139,21,56,0.08), transparent);"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-20 reveal">
      <p class="section-label mb-4">Nuestra Selección</p>
      <span class="gold-divider"></span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-cream mt-4" style="font-family: var(--font-family-display);">
        Nuestros Vinos
      </h2>
      <p class="mt-4 text-cream/60 max-w-xl mx-auto text-base" style="font-family: var(--font-family-body); font-weight: 300;">
        Cada botella, una historia. Cada sorbo, el terruño del Valle.
      </p>
    </div>

    <!-- Wine Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {wines.map((wine, i) => {
        const img = imageMap[wine.image];
        const delay = (i % 3) * 0.15;
        return (
          <article
            class={`wine-card reveal reveal-delay-${(i % 3) + 1} group relative rounded-sm overflow-hidden flex flex-col`}
            style={`background: linear-gradient(145deg, rgba(30,16,20,0.95), rgba(18,10,12,0.98)); border: 1px solid rgba(212,175,55,0.12); transition-delay: ${delay}s;`}
            aria-label={wine.name}
          >
            <!-- Image container -->
            <div class="relative overflow-hidden" style="height: 280px;">
              {img && (
                <Image
                  src={img}
                  alt={wine.imageAlt}
                  width={400}
                  height={280}
                  class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              )}
              <!-- Image gradient -->
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(18,10,12,0.95) 0%, rgba(18,10,12,0.2) 50%, transparent 100%);"></div>
              
              <!-- Badge -->
              {wine.badge && (
                <div class="absolute top-4 left-4">
                  <span
                    class="text-xs font-semibold px-3 py-1 rounded-sm"
                    style={`${badgeStyles[wine.badgeColor || 'gold']} font-family: var(--font-family-body); letter-spacing: 0.05em; font-size: 0.65rem; text-transform: uppercase;`}
                  >
                    {wine.badge}
                  </span>
                </div>
              )}

              <!-- Vintage on image -->
              {wine.vintage && (
                <div class="absolute top-4 right-4">
                  <span class="text-xs text-gold/80 font-display" style="font-family: var(--font-family-display);">
                    {wine.vintage}
                  </span>
                </div>
              )}
            </div>

            <!-- Card Content -->
            <div class="flex flex-col flex-1 p-6">
              <div class="mb-3">
                <p class="text-xs text-gold/70 uppercase tracking-wider mb-1" style="font-family: var(--font-family-body); letter-spacing: 0.12em; font-size: 0.65rem;">
                  {wine.grapes}
                </p>
                <h3 class="text-xl font-bold text-cream" style="font-family: var(--font-family-display);">
                  {wine.name}
                </h3>
              </div>

              <p class="text-cream/60 text-sm leading-relaxed mb-4 flex-1" style="font-family: var(--font-family-body); font-weight: 300;">
                {wine.description}
              </p>

              <!-- Tasting Notes -->
              <div class="mt-auto pt-4" style="border-top: 1px solid rgba(212,175,55,0.15);">
                <p class="text-xs text-gold/60 uppercase tracking-wider mb-2" style="font-family: var(--font-family-body); letter-spacing: 0.1em; font-size: 0.6rem;">
                  Notas de Cata
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {wine.notes.map((note) => (
                    <span
                      class="text-xs px-2.5 py-1 rounded-sm text-cream/70"
                      style="background: rgba(212,175,55,0.08); border: 1px solid rgba(212,175,55,0.15); font-family: var(--font-family-body); font-size: 0.7rem;"
                    >
                      {note}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Hover accent border -->
            <div
              class="absolute inset-0 rounded-sm pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              style="border: 1px solid rgba(212,175,55,0.35); box-shadow: inset 0 0 30px rgba(139,21,56,0.1);"
            ></div>
          </article>
        );
      })}
    </div>

    <!-- CTA below grid -->
    <div class="text-center mt-16 reveal">
      <a href="#contacto" class="btn-outline">
        Consulta Disponibilidad
      </a>
    </div>
  </div>
</section>
