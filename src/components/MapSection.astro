<!-- Visit & Contact Section -->
<section
    class="bg-background-light dark:bg-background-dark relative"
    id="visitanos"
>
    <div class="grid lg:grid-cols-2 min-h-[600px]">
        <!-- Contact Info & Form -->
        <div
            class="p-8 lg:p-20 flex flex-col justify-center bg-[#2A181E] text-white"
        >
            <span
                class="text-gold font-bold uppercase tracking-widest text-sm mb-4"
                >Visítanos</span
            >
            <h2 class="font-serif text-4xl lg:text-5xl font-bold mb-8">
                Vive la Experiencia
            </h2>
            <p class="text-gray-300 mb-10 max-w-md">
                Degustaciones, recorridos por los viñedos y eventos privados.
                Reserva tu lugar y déjanos ser tus anfitriones.
            </p>
            <div class="grid sm:grid-cols-2 gap-8 mb-12">
                <div>
                    <div class="flex items-center gap-3 mb-2 text-gold">
                        <span class="material-symbols-outlined">schedule</span>
                        <span class="font-bold uppercase text-sm tracking-wider"
                            >Horarios</span
                        >
                    </div>
                    <p class="text-gray-300">
                        Viernes 4–8 p.m. <br /> Sábado 12–8 p.m. <br /> Domingo 12–4
                        p.m.
                    </p>
                </div>
                <div>
                    <div class="flex items-center gap-3 mb-2 text-gold">
                        <span class="material-symbols-outlined"
                            >location_on</span
                        >
                        <span class="font-bold uppercase text-sm tracking-wider"
                            >Ubicación</span
                        >
                    </div>
                    <p class="text-gray-300">
                        Ágata, 22756 Artículo Ciento Quince
                    </p>
                    <p class="text-gray-300">Baja California, México</p>
                </div>
            </div>
            <form
                class="space-y-4 max-w-md bg-white/5 p-6 rounded-lg border border-white/10"
            >
                <h3 class="text-lg font-bold mb-4">Reserva tu Degustación</h3>
                <div class="grid grid-cols-2 gap-4">
                    <input
                        class="bg-transparent border border-gray-600 rounded px-4 py-3 text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                        placeholder="Nombre"
                        type="text"
                    />
                    <input
                        class="bg-transparent border border-gray-600 rounded px-4 py-3 text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                        placeholder="Email"
                        type="email"
                    />
                </div>
                <textarea
                    class="w-full bg-transparent border border-gray-600 rounded px-4 py-3 text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                    placeholder="Mensaje"></textarea>
                <button
                    class="w-full bg-primary hover:bg-white hover:text-primary-dark text-white font-bold py-3 rounded transition-colors uppercase tracking-widest text-sm"
                >
                    Enviar Mensaje
                </button>
            </form>
        </div>
        <!-- Map / Image Side -->
        <div class="relative h-full min-h-[400px]">
            <div
                class="w-full h-full bg-cover bg-center"
                data-alt="Map view of winery location in Valle de Guadalupe"
                data-location="Valle de Guadalupe"
            >
                <!-- iframe -->
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d845.1295948875168!2d-116.574722761865!3d32.082272821650136!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80d8f1d38660b6e5%3A0xe5bb1600b65cec29!2sCava%20ZARAGOZA!5e0!3m2!1ses-419!2smx!4v1771304137290!5m2!1ses-419!2smx"
                    class="w-full h-full border-0"
                    allowfullscreen=""
                    title="Mapa Cava Zaragoza"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</section>
