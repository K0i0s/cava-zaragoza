---
import "../styles/global.css";
import { Image } from "astro:assets";
import cavaLogo from "../assets/cava-logo.png";
---

<!-- Top Navigation -->
<nav
    class="sticky top-0 z-50 w-full border-b border-[#45262f]/30 bg-background-dark/95 backdrop-blur-sm"
>
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <div class="flex items-center gap-3 text-white">
                <a href="#">
                    <Image
                        src={cavaLogo}
                        alt="Cava Zaragoza Logo"
                        width={300}
                        height={300}
                        class="w-32 h-auto"
                    />
                </a>
            </div>
            <div class="hidden md:flex flex-1 justify-end items-center gap-8">
                <div class="flex items-center gap-8">
                    <a
                        class="text-white/80 hover:text-gold transition-colors text-sm font-medium uppercase tracking-widest"
                        href="#historia">Historia</a
                    >
                    <a
                        class="text-white/80 hover:text-gold transition-colors text-sm font-medium uppercase tracking-widest"
                        href="#vinos">Vinos</a
                    >
                    <a
                        class="text-white/80 hover:text-gold transition-colors text-sm font-medium uppercase tracking-widest"
                        href="#premios">Premios</a
                    >
                    <a
                        class="text-white/80 hover:text-gold transition-colors text-sm font-medium uppercase tracking-widest"
                        href="#visitanos">Visítanos</a
                    >
                </div>
                <button
                    class="bg-primary hover:bg-primary-dark transition-colors text-white px-6 py-2.5 rounded-lg text-sm font-bold uppercase tracking-wide shadow-lg shadow-primary/20"
                >
                    Comprar
                </button>
            </div>
            <!-- Mobile menu button -->
            <div class="md:hidden flex items-center">
                <button class="text-white p-2">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </div>
</nav>
